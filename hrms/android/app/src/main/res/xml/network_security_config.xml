<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (http://) is allowed ONLY for local development servers.
  Production / real domains stay HTTPS-only via the base-config below, so
  this does not weaken release security (private LAN IPs are unreachable in
  production anyway). Add your dev machine's LAN IP here if it changes.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.0.23</domain>
        <domain includeSubdomains="false">192.168.0.27</domain>
        <domain includeSubdomains="false">192.168.0.28</domain>
        <domain includeSubdomains="false">192.168.1.33</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
